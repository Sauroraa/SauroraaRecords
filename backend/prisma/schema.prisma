// ─── Sauroraa Engage System ───────────────────────────────────────────────────

model EngageCampaign {
  id                 String               @id @default(cuid())
  artistId           String
  releaseId          String?
  title              String
  description        String?              @db.Text
  status             EngageCampaignStatus @default(ACTIVE)
  downloadPath       String?
  soundcloudArtistId String?
  soundcloudTrackId  String?
  instagramHandle    String?
  discordServerId    String?
  discordInviteUrl   String?
  newsletterTag      String?
  releaseCountdown   DateTime?
  pixelFacebookId    String?
  pixelGoogleId      String?
  customCss          String?              @db.Text
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  artist   Artist                 @relation(fields: [artistId], references: [id], onDelete: Cascade)
  release  Release?               @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  actions  EngageCampaignAction[]
  sessions EngageSession[]
  subscribers EngageNewsletterSubscriber[]

  @@index([artistId, status, createdAt])
  @@index([releaseId])
}

model EngageCampaignAction {
  id         String           @id @default(cuid())
  campaignId String
  actionType EngageActionType
  required   Boolean          @default(true)
  position   Int              @default(0)
  label      String?

  campaign    EngageCampaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  completions EngageActionCompletion[]

  @@index([campaignId, position])
}

model EngageSession {
  id             String    @id @default(cuid())
  campaignId     String
  userId         String?
  email          String?
  ipAddress      String?
  userAgent      String?
  country        String?
  completed      Boolean   @default(false)
  downloadToken  String?   @unique
  tokenExpiresAt DateTime?
  sharedAfter    Boolean   @default(false)
  createdAt      DateTime  @default(now())

  campaign    EngageCampaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user        User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  completions EngageActionCompletion[]

  @@index([campaignId, completed, createdAt])
  @@index([downloadToken])
}

model EngageActionCompletion {
  id          String   @id @default(cuid())
  sessionId   String
  actionId    String
  completedAt DateTime @default(now())

  session EngageSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  action  EngageCampaignAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, actionId])
}

model EngageNewsletterSubscriber {
  id         String   @id @default(cuid())
  campaignId String
  artistId   String
  email      String
  firstName  String?
  createdAt  DateTime @default(now())

  campaign EngageCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, email])
  @@index([artistId, createdAt])
}
