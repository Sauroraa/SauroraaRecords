generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  ARTIST
  ADMIN
}

enum ReleaseType {
  FREE
  PAID
}

enum RevenueStatus {
  PENDING
  PAID
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(CLIENT)
  createdAt    DateTime @default(now())
  artist       Artist?
  orders       Order[]
  refreshTokens RefreshToken[]
}

model Artist {
  id         String    @id @default(cuid())
  userId     String    @unique
  bio        String?
  avatar     String?
  payoutIban String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  releases   Release[]
  revenues   ArtistRevenue[]
}

model Release {
  id          String      @id @default(cuid())
  artistId    String
  slug        String      @unique
  title       String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  type        ReleaseType
  audioPath   String
  coverPath   String?
  createdAt   DateTime    @default(now())
  artist      Artist      @relation(fields: [artistId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  total           Decimal     @db.Decimal(10, 2)
  stripeSessionId String?     @unique
  createdAt       DateTime    @default(now())
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  releaseId String
  price     Decimal  @db.Decimal(10, 2)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  release   Release  @relation(fields: [releaseId], references: [id], onDelete: Restrict)
}

model ArtistRevenue {
  id         String        @id @default(cuid())
  artistId   String
  month      String
  totalSales Decimal       @db.Decimal(10, 2)
  commission Decimal       @db.Decimal(10, 2)
  netDue     Decimal       @db.Decimal(10, 2)
  status     RevenueStatus @default(PENDING)
  artist     Artist        @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, month])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
