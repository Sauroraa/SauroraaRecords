generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  CLIENT
  ARTIST
  AGENCY
  STAFF
  ADMIN
}

enum SubscriptionPlan {
  ARTIST_FREE
  ARTIST_BASIC
  ARTIST_PRO
  AGENCY_START
  AGENCY_PRO
}

enum ReleaseType {
  FREE
  PAID
}

enum ReleaseVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum ReleaseFileType {
  MASTER
  HLS_FULL_PLAYLIST
  HLS_PREVIEW_PLAYLIST
  HLS_SEGMENT
  WAVEFORM
}

enum StreamScope {
  PREVIEW
  FULL
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  FAILED
}

enum LedgerEntryType {
  SALE_GROSS
  PLATFORM_COMMISSION
  ARTIST_NET
  PAYOUT
  REFUND
}

enum PrivateLinkScope {
  STREAM
  DOWNLOAD
}

enum PromotionType {
  HOMEPAGE_FEATURE
  FOLLOWER_PUSH
  DISCOVERY_BOOST
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum CollaboratorRole {
  PRIMARY
  FEATURED
  PRODUCER
  REMIXER
}

enum AiTaggingJobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

enum ClaimStatus {
  OPEN
  UNDER_REVIEW
  SUSPENDED_CONTENT
  RESOLVED
  REJECTED
}

enum ReportTargetType {
  RELEASE
  COMMENT
  USER
}

enum ReportStatus {
  OPEN
  BOT_REVIEWED
  STAFF_REVIEW
  ACTION_TAKEN
  CLOSED
}

enum ModerationActionType {
  WARNING
  REMOVE_CONTENT
  SUSPEND_USER
  REINSTATE_CONTENT
  BAN_USER
}

enum DuplicateAlertStatus {
  NEW
  CONFIRMED
  FALSE_POSITIVE
  IGNORED
}

enum PayoutProvider {
  STRIPE_CONNECT
  PAYPAL
  SEPA
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum ExportFormat {
  CSV
  PDF
}

enum ExportStatus {
  QUEUED
  DONE
  FAILED
}

enum AssetPackType {
  STEM
  SAMPLE_PACK
  PRESET_PACK
}

enum RevenueStatus {
  PENDING
  PAID
}

enum AgencyRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FreeDownloadActionType {
  FOLLOW_ARTIST
  SUBSCRIBE_NEWSLETTER
  LEAVE_COMMENT
  SHARE_LINK
  FOLLOW_INSTAGRAM
  FOLLOW_SOUNDCLOUD
  JOIN_DISCORD
}

enum EngageActionType {
  FOLLOW_SOUNDCLOUD
  LIKE_SOUNDCLOUD
  REPOST_SOUNDCLOUD
  FOLLOW_INSTAGRAM
  JOIN_DISCORD
  SUBSCRIBE_NEWSLETTER
  FOLLOW_ARTIST
  LEAVE_COMMENT
}

enum EngageCampaignStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportMessageAuthorType {
  USER
  AGENT
  BOT
}

// ─── Core User & Auth ─────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  role           UserRole  @default(CLIENT)
  firstName      String?
  lastName       String?
  avatarUrl      String?
  dateOfBirth    DateTime?
  addressLine1   String?
  addressLine2   String?
  postalCode     String?
  city           String?
  country        String?
  hasSociete     Boolean   @default(false)
  societeName    String?
  vatNumber      String?
  billingAddress String?
  createdAt      DateTime  @default(now())

  artist           Artist?
  agency           Agency?
  subscription     Subscription?
  orders           Order[]
  refreshTokens    RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  comments         Comment[]
  commentLikes     CommentLike[]
  follows          Follow[]
  notifications    Notification[]
  downloadSessions FreeDownloadSession[]
  preorders        Preorder[]
  tipsGiven        Tip[]                 @relation("TipUser")
  gateSubmissions  GateSubmission[]
  requestedSupportTickets SupportTicket[] @relation("SupportRequester")
  assignedSupportTickets  SupportTicket[] @relation("SupportAssignee")
  supportMessages         SupportMessage[] @relation("SupportAuthor")
  streamEvents            StreamEvent[]
  playlists               Playlist[]
  reposts                 Repost[]
  privateLinks            PrivateListeningLink[]
  fanScores               FanScore[] @relation("FanUser")
  leakFingerprints        LeakFingerprint[]
  aiTaggingJobs           AiTaggingJob[]
  dmcaClaimsFiled         DmcaClaim[] @relation("ClaimReporter")
  reportsFiled            ContentReport[] @relation("ReportReporter")
  reportedAsUser          ContentReport[] @relation("ReportTargetUser")
  moderationActions       ModerationAction[]
  fanBadgeAssignments     UserFanBadge[]
  premiereChatMessages    PremiereChatMessage[]
  broadcastRecipients     ArtistBroadcastRecipient[]
  accountingExports       AccountingExport[]
  recoveryTokens          SecurityRecoveryToken[]
  twoFactor               UserTwoFactor?
  loginAlerts             LoginAlert[]
  pushDevices             PushDevice[]
  publicApiClientsCreated PublicApiClient[]
  embedWidgets            EmbedWidget[]
  engageSessions          EngageSession[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Artist ───────────────────────────────────────────────────────────────────

model Artist {
  id            String    @id @default(cuid())
  userId        String    @unique
  displayName   String?
  bio           String?   @db.Text
  avatar        String?
  bannerUrl     String?
  payoutIban    String?
  instagramUrl  String?
  soundcloudUrl String?
  discordUrl    String?
  websiteUrl    String?
  isVerified    Boolean   @default(false)
  verifiedAt    DateTime?

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  releases       Release[]
  dubpacks       Dubpack[]
  revenues       ArtistRevenue[]
  rankings       ArtistRanking[]
  followers      Follow[]
  downloadConfig ArtistDownloadConfig?
  tipsReceived   Tip[]                 @relation("TipArtist")
  agencyLinks    AgencyArtist[]
  gateSubmissions GateSubmission[]
  invoices       Invoice[]
  ledgerEntries  LedgerEntry[]
  collaborations ReleaseCollaborator[]
  fanScores      FanScore[] @relation("FanArtist")
  promotions     PromotionCampaign[]
  trustScore     ArtistTrustScore?
  premiereEvents PremiereEvent[]
  broadcasts     ArtistBroadcast[]
  payoutAccount  PayoutAccount?
  payouts        PayoutTransaction[]
  fanBadgeAssignments UserFanBadge[]
  engageCampaigns EngageCampaign[]
}

// ─── Subscription ─────────────────────────────────────────────────────────────

model Subscription {
  id                   String           @id @default(cuid())
  userId               String           @unique
  plan                 SubscriptionPlan
  stripeSubscriptionId String?          @unique
  stripeCustomerId     String?
  status               String           @default("active")
  currentPeriodEnd     DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Agency ───────────────────────────────────────────────────────────────────

model Agency {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String?
  logoPath    String?
  createdAt   DateTime @default(now())

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  artists     AgencyArtist[]
  invitations AgencyInvitation[]
}

model AgencyArtist {
  id        String @id @default(cuid())
  agencyId  String
  artistId  String
  createdAt DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([agencyId, artistId])
}

// ─── Release ──────────────────────────────────────────────────────────────────

model Release {
  id                     String      @id @default(cuid())
  artistId               String
  slug                   String      @unique
  title                  String
  genre                  String?
  description            String?     @db.Text
  price                  Decimal     @db.Decimal(10, 2)
  type                   ReleaseType
  audioPath              String
  previewClip            String?
  coverPath              String?
  published              Boolean     @default(false)
  visibility             ReleaseVisibility @default(PUBLIC)
  exclusiveFollowersOnly Boolean     @default(false)
  releaseDate            DateTime?
  bpm                    Int?
  musicalKey             String?
  tags                   Json?
  mood                   String?
  energy                 Int?
  earlyAccessAt          DateTime?
  previewDuration        Int         @default(30)
  isPaid                 Boolean     @default(false)
  hlsFullPath            String?
  hlsPreviewPath         String?
  waveformPath           String?
  hlsReady               Boolean     @default(false)
  processingStatus       String      @default("PENDING")
  // HypeEdit gate
  gateEnabled            Boolean     @default(false)
  gateFollowArtist       Boolean     @default(false)
  gateEmail              Boolean     @default(false)
  gateInstagram          Boolean     @default(false)
  gateSoundcloud         Boolean     @default(false)
  gateDiscord            Boolean     @default(false)
  createdAt              DateTime    @default(now())

  artist           Artist                @relation(fields: [artistId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
  comments         Comment[]
  downloadSessions FreeDownloadSession[]
  preorders        Preorder[]
  gateSubmissions  GateSubmission[]
  files            ReleaseFile[]
  streamEvents     StreamEvent[]
  ledgerEntries    LedgerEntry[]
  collaborators    ReleaseCollaborator[]
  privateLinks     PrivateListeningLink[]
  reposts          Repost[]
  promotions       PromotionCampaign[]
  aiTaggingJobs    AiTaggingJob[]
  leakFingerprints LeakFingerprint[]
  playlistTracks   PlaylistTrack[]
  dmcaClaims       DmcaClaim[]
  contentReports   ContentReport[]
  duplicateAlerts  DuplicateAudioAlert[] @relation("DuplicateRelease")
  matchedDuplicateAlerts DuplicateAudioAlert[] @relation("DuplicateMatchedRelease")
  moderationFlags  AiModerationFlag[]
  releaseSchedule  ReleaseSchedule?
  shareCards       ViralShareCard[]
  premiereEvent    PremiereEvent?
  trackVersions    TrackVersion[]
  listeningHeatmap ListeningHeatmap[]
  assetPacks       ReleaseAssetPack[]
  embedWidgets     EmbedWidget[]
  smartTagSuggestion SmartTagSuggestion?
  engageCampaigns    EngageCampaign[]

  @@index([artistId, published, createdAt])
  @@index([published, genre, createdAt])
  @@index([slug, published])
}

// ─── Dubpack ──────────────────────────────────────────────────────────────────

model Dubpack {
  id                     String      @id @default(cuid())
  artistId               String
  slug                   String      @unique
  title                  String
  genre                  String?
  description            String?     @db.Text
  price                  Decimal     @db.Decimal(10, 2)
  type                   ReleaseType
  coverPath              String?
  zipPath                String
  isExclusive            Boolean     @default(false)
  published              Boolean     @default(false)
  exclusiveFollowersOnly Boolean     @default(false)
  createdAt              DateTime    @default(now())

  artist           Artist                @relation(fields: [artistId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
  comments         Comment[]
  downloadSessions FreeDownloadSession[]
  preorders        Preorder[]
}

// ─── Orders & Shop ────────────────────────────────────────────────────────────

model Order {
  id              String    @id @default(cuid())
  userId          String
  total           Decimal   @db.Decimal(10, 2)
  stripeSessionId String?   @unique
  status          String    @default("completed")
  createdAt       DateTime  @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]
  ledgerEntries LedgerEntry[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  releaseId String?
  dubpackId String?
  price     Decimal @db.Decimal(10, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  release Release? @relation(fields: [releaseId], references: [id], onDelete: Restrict)
  dubpack Dubpack? @relation(fields: [dubpackId], references: [id], onDelete: Restrict)
}

// ─── Revenue & Invoicing ──────────────────────────────────────────────────────

model ArtistRevenue {
  id         String        @id @default(cuid())
  artistId   String
  month      String
  totalSales Decimal       @db.Decimal(10, 2)
  commission Decimal       @db.Decimal(10, 2)
  netDue     Decimal       @db.Decimal(10, 2)
  status     RevenueStatus @default(PENDING)

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, month])
  @@index([month])
}

model ArtistRanking {
  id             String  @id @default(cuid())
  artistId       String
  month          String
  totalDownloads Int     @default(0)
  totalRevenue   Decimal @db.Decimal(10, 2) @default(0)
  rank           Int     @default(0)

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, month])
}

// ─── Social: Comments ─────────────────────────────────────────────────────────

model Comment {
  id                 String   @id @default(cuid())
  userId             String
  releaseId          String?
  dubpackId          String?
  parentId           String?
  body               String   @db.Text
  timestampSec       Int?
  likesCount         Int      @default(0)
  isVerifiedPurchase Boolean  @default(false)
  createdAt          DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  release Release?    @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  dubpack Dubpack?    @relation(fields: [dubpackId], references: [id], onDelete: Cascade)
  parent  Comment?    @relation("Replies", fields: [parentId], references: [id])
  replies Comment[]   @relation("Replies")
  likes   CommentLike[]
  reports ContentReport[]
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

// ─── Social: Follows ──────────────────────────────────────────────────────────

model Follow {
  id         String   @id @default(cuid())
  followerId String
  artistId   String
  createdAt  DateTime @default(now())

  follower User   @relation(fields: [followerId], references: [id], onDelete: Cascade)
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([followerId, artistId])
  @@index([artistId, createdAt])
}

model Playlist {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?  @db.Text
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks PlaylistTrack[]

  @@index([userId, createdAt])
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  releaseId  String
  position   Int
  addedAt    DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  release  Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([playlistId, releaseId])
  @@unique([playlistId, position])
  @@index([releaseId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  body      String   @db.Text
  isRead    Boolean  @default(false)
  releaseId String?
  dubpackId String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Free Download / Hypeddit System ─────────────────────────────────────────

model FreeDownloadSession {
  id             String    @id @default(cuid())
  userId         String
  releaseId      String?
  dubpackId      String?
  downloadToken  String?   @unique
  tokenExpiresAt DateTime?
  createdAt      DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  release Release? @relation(fields: [releaseId], references: [id])
  dubpack Dubpack? @relation(fields: [dubpackId], references: [id])
  actions FreeDownloadAction[]
}

model FreeDownloadAction {
  id          String                 @id @default(cuid())
  sessionId   String
  action      FreeDownloadActionType
  completedAt DateTime?

  session FreeDownloadSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model ArtistDownloadConfig {
  id              String  @id @default(cuid())
  artistId        String  @unique
  enabled         Boolean @default(true)
  requiredActions Json

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
}

// ─── Preorders ────────────────────────────────────────────────────────────────

model Preorder {
  id              String    @id @default(cuid())
  userId          String
  releaseId       String?
  dubpackId       String?
  releaseDate     DateTime
  paidAt          DateTime?
  stripeSessionId String?
  createdAt       DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  release Release? @relation(fields: [releaseId], references: [id])
  dubpack Dubpack? @relation(fields: [dubpackId], references: [id])
}

// ─── Promo Codes ─────────────────────────────────────────────────────────────

model PromoCode {
  id        String    @id @default(cuid())
  code      String    @unique
  discount  Int
  maxUses   Int       @default(100)
  uses      Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

// ─── Tips ─────────────────────────────────────────────────────────────────────

model Tip {
  id              String   @id @default(cuid())
  userId          String
  artistId        String
  amount          Decimal  @db.Decimal(10, 2)
  stripeSessionId String?
  createdAt       DateTime @default(now())

  user   User   @relation("TipUser", fields: [userId], references: [id], onDelete: Cascade)
  artist Artist @relation("TipArtist", fields: [artistId], references: [id], onDelete: Cascade)
}

// ─── Agency Requests ──────────────────────────────────────────────────────────

model AgencyRequest {
  id        String              @id @default(cuid())
  email     String
  firstName String?
  lastName  String?
  company   String?
  message   String?             @db.Text
  status    AgencyRequestStatus @default(PENDING)
  createdAt DateTime            @default(now())
}

// ─── Agency Artist Invitations ────────────────────────────────────────────────

model AgencyInvitation {
  id        String   @id @default(cuid())
  agencyId  String
  email     String
  token     String   @unique @default(cuid())
  accepted  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}

// ─── HypeEdit Gate ────────────────────────────────────────────────────────────

model GateSubmission {
  id        String   @id @default(cuid())
  releaseId String
  artistId  String
  userId    String?
  email     String?
  createdAt DateTime @default(now())

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  artist  Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([releaseId, createdAt])
  @@index([artistId, createdAt])
}

// ─── Support ─────────────────────────────────────────────────────────────────

model SupportTicket {
  id           String                @id @default(cuid())
  subject      String
  category     String?
  status       SupportTicketStatus   @default(OPEN)
  priority     SupportTicketPriority @default(NORMAL)
  userId       String
  assignedToId String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  closedAt     DateTime?

  user      User           @relation("SupportRequester", fields: [userId], references: [id], onDelete: Cascade)
  assignedTo User?         @relation("SupportAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages  SupportMessage[]
}

model SupportMessage {
  id         String                   @id @default(cuid())
  ticketId   String
  authorType SupportMessageAuthorType @default(USER)
  authorId   String?
  body       String                   @db.Text
  createdAt  DateTime                 @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User?         @relation("SupportAuthor", fields: [authorId], references: [id], onDelete: SetNull)
}

model ReleaseCollaborator {
  id          String           @id @default(cuid())
  releaseId   String
  artistId    String
  role        CollaboratorRole @default(FEATURED)
  invitedById String?
  accepted    Boolean          @default(false)
  createdAt   DateTime         @default(now())

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  artist  Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([releaseId, artistId, role])
  @@index([artistId, accepted])
}

model PrivateListeningLink {
  id          String           @id @default(cuid())
  token       String           @unique
  scope       PrivateLinkScope @default(STREAM)
  releaseId   String
  creatorId   String
  expiresAt   DateTime
  maxPlays    Int              @default(50)
  playsCount  Int              @default(0)
  createdAt   DateTime         @default(now())
  lastUsedAt  DateTime?

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([releaseId, expiresAt])
}

model Repost {
  id        String   @id @default(cuid())
  userId    String
  releaseId String
  message   String?  @db.Text
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([userId, releaseId])
  @@index([createdAt])
}

model FanScore {
  id          String   @id @default(cuid())
  userId      String
  artistId    String
  score       Int      @default(0)
  streams     Int      @default(0)
  purchases   Int      @default(0)
  reposts     Int      @default(0)
  comments    Int      @default(0)
  updatedAt   DateTime @updatedAt

  user   User   @relation("FanUser", fields: [userId], references: [id], onDelete: Cascade)
  artist Artist @relation("FanArtist", fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([userId, artistId])
  @@index([artistId, score])
}

model PromotionCampaign {
  id            String          @id @default(cuid())
  artistId      String
  releaseId     String?
  promotionType PromotionType
  title         String
  budgetCents   Int             @default(0)
  status        PromotionStatus @default(DRAFT)
  startAt       DateTime?
  endAt         DateTime?
  createdAt     DateTime        @default(now())

  artist  Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  release Release? @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@index([artistId, status, createdAt])
}

model AiTaggingJob {
  id           String             @id @default(cuid())
  releaseId    String
  requestedBy  String
  status       AiTaggingJobStatus @default(QUEUED)
  result       Json?
  errorMessage String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [requestedBy], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([releaseId, createdAt])
}

model LeakFingerprint {
  id              String   @id @default(cuid())
  releaseId       String
  userId          String?
  fingerprintHash String
  watermarkRef    String?
  createdAt       DateTime @default(now())

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([releaseId, createdAt])
