PROJECT_NAME=sauroraa-records

# ─── Domains ─────────────────────────────────────────────────────────────────
# Records main platform
DOMAIN=localhost
RECORDS_BASE=http://localhost:3100
FRONTEND_URL=https://sauroraarecords.be

# Music streaming platform
# Prod: music.sauroraarecords.be → nginx music server block → music-web:3001
# Dev: add "127.0.0.1 music.localhost" to /etc/hosts, use http://music.localhost:3100
MUSIC_PUBLIC_URL=https://music.sauroraarecords.be

COOKIE_DOMAIN=.sauroraarecords.be
RECORDS_PUBLIC_URL=https://sauroraarecords.be/register

# ─── Database ─────────────────────────────────────────────────────────────────
MARIADB_ROOT_PASSWORD=change_me_root
MARIADB_DATABASE=sauroraa
MARIADB_USER=sauroraa
MARIADB_PASSWORD=change_me_db

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_jwt
JWT_REFRESH_SECRET=change_me_refresh

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ARTIST_BASIC=price_xxx
STRIPE_PRICE_ARTIST_PRO=price_xxx
STRIPE_PRICE_AGENCY_START=price_xxx
STRIPE_PRICE_AGENCY_PRO=price_xxx

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.us.appsuite.cloud
MAIL_PORT=587
MAIL_USER=contact@sauroraa.be
MAIL_PASSWORD=change_me_mail
MAIL_FROM="SauroraaRecords <contact@sauroraa.be>"

# ─── Storage ──────────────────────────────────────────────────────────────────
# Use "local" for dev, "s3" for prod (MinIO or AWS S3)
STORAGE_MODE=local

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=sauroraa
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_FORCE_PATH_STYLE=true

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# Optional CDN prefix for served media files
CDN_BASE_URL=

# ─── Streaming (HLS security) ─────────────────────────────────────────────────
# Short-lived tokens signed by nginx auth_request + backend verify endpoint
STREAM_SIGNING_SECRET=change_me_stream_secret
STREAM_TOKEN_TTL_SECONDS=30

# ─── Search (Meilisearch) ─────────────────────────────────────────────────────
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=change_me_meili_master_key
MEILISEARCH_API_KEY=
MEILISEARCH_RELEASES_INDEX=releases

# ─── Worker (FFmpeg audio processing) ────────────────────────────────────────
WORKER_QUEUE_NAME=audio:processing

# ─── Revenue / Commission ─────────────────────────────────────────────────────
# Fallback if no subscription plan found. Per-plan overrides:
#   ARTIST_FREE=30%  ARTIST_BASIC=20%  ARTIST_PRO=10%
#   AGENCY_START=20% AGENCY_PRO=10%
COMMISSION_RATE=0.30

# ─── Public API ───────────────────────────────────────────────────────────────
PUBLIC_API_RATE_LIMIT_DEFAULT=120
