PROJECT_NAME=sauroraa-records

DOMAIN=localhost

MARIADB_ROOT_PASSWORD=change_me_root
MARIADB_DATABASE=sauroraa
MARIADB_USER=sauroraa
MARIADB_PASSWORD=change_me_db

JWT_SECRET=change_me_jwt
JWT_REFRESH_SECRET=change_me_refresh

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Mail (configure with your provider)
MAIL_HOST=smtp.us.appsuite.cloud
MAIL_PORT=587
MAIL_USER=contact@sauroraa.be
MAIL_PASSWORD=change_me_mail
MAIL_FROM="SauroraaRecords <contact@sauroraa.be>"
FRONTEND_URL=https://sauroraarecords.be

S3_ENDPOINT=minio:9000
S3_REGION=us-east-1
S3_BUCKET=sauroraa
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_FORCE_PATH_STYLE=true

COMMISSION_RATE=0.10
STORAGE_MODE=local

# Streaming security
STREAM_SIGNING_SECRET=change_me_stream_secret
STREAM_TOKEN_TTL_SECONDS=30

# Search
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=change_me_meili_master_key
MEILISEARCH_API_KEY=
MEILISEARCH_RELEASES_INDEX=releases

# Worker queue
WORKER_QUEUE_NAME=audio:processing

# Minio
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# Optional CDN
CDN_BASE_URL=

# Public API
PUBLIC_API_RATE_LIMIT_DEFAULT=120
